{
  "name": "@ciagent/cli",
  "version": "0.1.0",
  "description": "CLI interface for ciagent - vendor-neutral AI agent tool",
  "type": "module",
  "main": "./src/cli.ts",
  "bin": {
    "cia": "./src/cli.ts"
  },
  "scripts": {
    "type-check": "bun tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "build": "bun run build:release",
    "build:dev": "bun build --compile --minify --sourcemap --bytecode src/cli.ts --outfile ../../dist/cia",
    "build:release": "bun build --compile --minify --bytecode src/cli.ts --outfile ../../dist/cia",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@ai-sdk/azure": "^3.0.54",
    "@ai-sdk/openai": "^3.0.53",
    "@anthropic-ai/claude-agent-sdk": "^0.2.112",
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.121.0",
    "@types/node": "^25.6.0",
    "ai": "^6.0.168",
    "ajv": "8.18.0",
    "axios": "1.15.0",
    "ignore": "^7.0.5",
    "open": "^11.0.0",
    "p-retry": "8.0.0",
    "simple-oauth2": "^5.1.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/json-schema": "^7.0.15",
    "@types/simple-oauth2": "^5.0.8",
    "@vitest/coverage-v8": "^4.1.4",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "cicd"
  ],
  "author": "ciagent",
  "license": "MIT"
}
