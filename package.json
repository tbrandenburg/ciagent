{
  "name": "ciagent",
  "version": "0.1.0",
  "description": "Vendor-neutral AI agent CLI tool for CI/CD pipelines",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "type-check": "npx tsc --noEmit",
    "lint": "eslint packages/*/src/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts --fix && prettier --write packages/*/src/**/*.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "build": "npm run build:release",
    "benchmark:run": "bash scripts/benchmarks/run-cli-startup.sh",
    "benchmark:collect": "bun scripts/benchmarks/collect-metrics.ts --input test-results/benchmarks/raw.json --output test-results/benchmarks/summary.json",
    "benchmark": "npm run benchmark:run && npm run benchmark:collect",
    "validate-bench": "npx vitest --run packages/cli/tests/benchmarks/*.test.ts && npm run benchmark",
    "build:dev": "cd packages/cli && bun run build:dev",
    "build:release": "cd packages/cli && bun run build:release",
    "build:cli": "npm run build:release",
    "dev:cli": "bun packages/cli/src/cli.ts",
    "ci": "npm run lint && npm run type-check && vitest run && echo 'Build step skipped (requires Bun)'"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "bun-types": "^1.3.12",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "minimatch": "^10.2.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "cicd",
    "devops",
    "automation"
  ],
  "author": "ciagent",
  "license": "MIT",
  "overrides": {
    "minimatch": "^10.2.5",
    "rollup": "^4.59.0", 
    "@hono/node-server": "^1.19.10",
    "vite": "^8.0.8",
    "express-rate-limit": "^8.2.2",
    "flatted": "^3.4.0",
    "path-to-regexp": "^8.4.0", 
    "picomatch": "^4.0.4",
    "hono": "^4.12.4"
  },
  "dependencies": {
    "axios": "1.15.0"
  }
}
